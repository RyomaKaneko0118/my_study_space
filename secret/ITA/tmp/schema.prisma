generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum CoordinatorRole {
  MAIN
  SUB
}

enum TrainingClassificationRole {
  MAIN
  SUB
}

enum TrainingClassificationCategory {
  NEW
  EXISTING
}

enum ContractType {
  PAPER
  ELECTRON
}

enum ContractCategory {
  BASE
  NDA
}

model Customer {
  id               Int       @id @default(autoincrement()) @db.UnsignedInt
  boardClientId    Int       @unique @map("board_client_id") @db.UnsignedInt
  saCompanyId      Int?      @unique @map("sa_company_id") @db.UnsignedInt
  archived         Boolean   @default(false)
  dealingStartDate DateTime  @map("dealing_start_date") @db.Date
  dealingEndDate   DateTime? @map("dealing_end_date")
  logoPath         String?   @unique @map("logo_path")
  sales            Int?      @db.UnsignedInt // NOTE: sort用で使用のため
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  // has many
  customerDetails         CustomerDetail[]
  customerPins            CustomerPin[]
  contracts               Contract[]
  departments             Department[]
  managers                Manager[]
  trainingClassifications TrainingClassification[]

  @@map("customers")
}

// NOTE: nameからaddress2まではboardAPIで取得する属性
model CustomerDetail {
  id            Int      @id @default(autoincrement()) @db.UnsignedInt
  customerId    Int      @map("customer_id") @db.UnsignedInt
  current       Boolean  @default(false)
  name          String
  nameDisp      String   @map("name_disp")
  sales         Int?
  zip           String?
  pref          String?
  address1      String?
  address2      String?
  financialYear Int      @map("financial_year")
  link          String   @default("")
  parent        String   @db.Text
  affiliate     String   @db.Text
  note          String   @db.Text
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  // belongs to
  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  // has many
  coordinators Coordinator[]

  @@unique(fields: [customerId, financialYear])
  @@map("customer_details")
}

model CustomerPin {
  id         Int @id @default(autoincrement()) @db.UnsignedInt
  customerId Int @map("customer_id") @db.UnsignedInt
  saUserId   Int @map("sa_user_id") @db.UnsignedInt

  // belongs to
  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@unique(fields: [customerId, saUserId])
  @@map("customer_pins")
}

model Coordinator {
  id               Int             @id @default(autoincrement()) @db.UnsignedInt
  customerDetailId Int             @map("customer_detail_id") @db.UnsignedInt
  saUserId         Int             @map("sa_user_id") @db.UnsignedInt
  role             CoordinatorRole
  createdAt        DateTime        @default(now()) @map("created_at")
  updatedAt        DateTime        @updatedAt @map("updated_at")

  // belongs to
  customerDetail CustomerDetail @relation(fields: [customerDetailId], references: [id], onDelete: Cascade)

  @@unique(fields: [customerDetailId, saUserId])
  @@map("coordinators")
}

model Department {
  id               Int       @id @default(autoincrement()) @db.UnsignedInt
  customerId       Int       @map("customer_id") @db.UnsignedInt
  name             String
  dealingStartDate DateTime  @map("dealing_start_date") @db.Date
  dealingEndDate   DateTime? @map("dealing_end_date") @db.Date
  note             String    @db.Text
  postalCode       String    @map("postal_code")
  prefectureCode   Int       @map("prefecture_code") @db.UnsignedTinyInt
  city             String
  town             String
  addressLine      String    @default("") @map("address_line")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  // belongs to
  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@map("departments")
}

model Contract {
  id               Int              @id @default(autoincrement()) @db.UnsignedInt
  customerId       Int              @map("customer_id") @db.UnsignedInt
  name             String
  departmentName   String           @default("") @map("department_name")
  contractor       String           @default("")
  contractType     ContractType     @map("contract_type")
  contractCategory ContractCategory @map("contract_category")
  dealingStartDate DateTime         @map("dealing_start_date") @db.Date
  dealingEndDate   DateTime         @map("dealing_end_date") @db.Date
  autoUpdated      Boolean          @default(false) @map("auto_updated")
  createdAt        DateTime         @default(now()) @map("created_at")
  updatedAt        DateTime         @updatedAt @map("updated_at")

  // belongs to
  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@map("contracts")
}

model Manager {
  id             Int       @id @default(autoincrement()) @db.UnsignedInt
  customerId     Int       @map("customer_id") @db.UnsignedInt
  firstName      String    @map("first_name")
  lastName       String    @map("last_name")
  firstNameKana  String    @map("first_name_kana")
  lastNameKana   String    @map("last_name_kana")
  departmentName String    @default("") @map("department_name")
  email          String    @default("")
  telephone      String    @default("")
  startDate      DateTime  @map("start_date") @db.Date
  endDate        DateTime? @map("end_date") @db.Date
  post           String    @default("")
  roleDetails    String    @default("") @map("role_details")
  note           String    @db.Text
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  // belongs to
  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  //has many
  trainingClassificationManagers TrainingClassificationManager[]

  @@map("managers")
}

model TrainingClassification {
  id             Int                            @id @default(autoincrement()) @db.UnsignedInt
  customerId     Int                            @map("customer_id") @db.UnsignedInt
  name           TrainingClassificationCategory
  departmentName String
  year           Int
  trainingPeriod Int                            @map("training_period") @db.UnsignedInt
  sales          Int?                           @db.UnsignedInt
  note           String                         @db.Text
  createdAt      DateTime                       @default(now()) @map("created_at")
  updatedAt      DateTime                       @updatedAt @map("updated_at")

  // belongs to
  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  //has many
  trainingClassificationManagers     TrainingClassificationManager[]
  trainingClassificationCoordinators TrainingClassificationCoordinator[]

  @@map("training_classifications")
}

model TrainingClassificationManager {
  id                       Int @id @default(autoincrement()) @db.UnsignedInt
  trainingClassificationId Int @map("training_classification_id") @db.UnsignedInt
  managerId                Int @map("manager_id") @db.UnsignedInt

  role      TrainingClassificationRole
  createdAt DateTime                   @default(now()) @map("created_at")
  updatedAt DateTime                   @updatedAt @map("updated_at")

  // belongs to
  manager                Manager                @relation(fields: [managerId], references: [id])
  trainingClassification TrainingClassification @relation(fields: [trainingClassificationId], references: [id])

  @@unique(fields: [trainingClassificationId, managerId])
  @@map("training_classification_managers")
}

model TrainingClassificationCoordinator {
  id                       Int                        @id @default(autoincrement()) @db.UnsignedInt
  trainingClassificationId Int                        @map("training_classification_id") @db.UnsignedInt
  saUserId                 Int                        @map("sa_user_id") @db.UnsignedInt
  role                     TrainingClassificationRole
  createdAt                DateTime                   @default(now()) @map("created_at")
  updatedAt                DateTime                   @updatedAt @map("updated_at")

  // belongs to
  trainingClassification TrainingClassification @relation(fields: [trainingClassificationId], references: [id])

  @@unique(fields: [trainingClassificationId, saUserId])
  @@map("training_classification_coordinators")
}
