{
  "extends": "./.svelte-kit/tsconfig.json",
  "compilerOptions": {
    "allowJs": true,
    "checkJs": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "noImplicitAny": false,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "sourceMap": true,
    "strict": true,
    "ignoreDeprecations": "5.0",
    "importsNotUsedAsValues": "error",
    "baseUrl": "./",
    "paths": {
      "$api/*": ["src/api/*"],
      "$assets/*": ["src/assets/*"],
      "$lib/*": ["src/lib/*"],
      "$routes/*": ["src/routes/*"],
      "$stores/*": ["src/stores/*"]
    }
  }
}
