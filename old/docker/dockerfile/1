FROM ruby:2.5.3
# build-essential、mysql-client、vimをインストール
RUN apt-get update -qq && apt-get install -y build-essential mysql-client vim
# nodejs用のリポジトリを作成
RUN curl -sL https://deb.nodesource.com/setup_12.x | bash
RUN apt-get install -y nodejs
# yarnをインストールするために、パッケージリポジトリの公開鍵を取得。
# APTパッケージマネージャーに追加。
# /etc/apt/sources.list.d/yarn.listに、
# deb https://dl.yarnpkg.com/debian/ stable mainと記入。
RUN curl -sS https://dl.yarnpkg.com/debian/pubkey.gpg | apt-key add -
RUN echo "deb https://dl.yarnpkg.com/debian/ stable main" | tee /etc/apt/sources.list.d/yarn.list
RUN apt-get update -qq && apt-get install yarn
RUN groupadd -r --gid 1000 rails && useradd -m -r --uid 1000 --gid 1000 rails
RUN mkdir /seminar-assist
RUN chown -R rails:rails /seminar-assist
USER rails
WORKDIR /seminar-assist
ADD . /seminar-assist
ENV RUBYOPT -EUTF-8